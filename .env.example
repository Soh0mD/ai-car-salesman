# Copy this file to .env.local and fill in what you have. Never commit .env.local.

# ── Required ───────────────────────────────────────────────────────────────
# Claude API key. Set a monthly spend limit at console.anthropic.com — that cap
# is what makes a public demo safe.
ANTHROPIC_API_KEY=

# ── Inventory sources (recommended; each missing key just skips that source) ──
MARKETCHECK_API_KEY=
AUTODEV_API_KEY=
# eBay Browse API — needs PRODUCTION (not sandbox) App ID + Cert ID.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# (NHTSA recalls/complaints/safety and FuelEconomy.gov MPG are free & keyless.)

# ── Optional infra ───────────────────────────────────────────────────────────
# Upstash Redis: response cache + per-IP rate limit + saved-search storage.
# Absent = those features no-op (the app still runs).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend: saved-search alert emails (new matches / price drops).
# ALERT_FROM_EMAIL must be on a Resend-verified domain (e.g. alerts@dascar.xyz).
RESEND_API_KEY=
ALERT_FROM_EMAIL=

# Secret for the daily alert cron (/api/alerts/cron). Vercel sends it as a
# Bearer token on scheduled invocations; generate a long random string.
CRON_SECRET=
